<?xml version="1.0"?>
<rdf:RDF xmlns="http://www.semanticweb.org/movieontology#"
     xml:base="http://www.semanticweb.org/movieontology"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:dc="http://purl.org/dc/elements/1.1/"
     xmlns:dcterms="http://purl.org/dc/terms/"
     xmlns:schema="http://schema.org/"
     xmlns:dbo="http://dbpedia.org/ontology/"
     xmlns:wd="http://www.wikidata.org/entity/"
     xmlns:wdt="http://www.wikidata.org/prop/direct/"
     xmlns:mo="http://www.movieontology.org/2009/11/09/movieontology.owl#"
     xmlns:foaf="http://xmlns.com/foaf/0.1/"
     xmlns:skos="http://www.w3.org/2004/02/skos/core#"
     xmlns:movie="http://www.semanticweb.org/movieontology#">

    <owl:Ontology rdf:about="http://www.semanticweb.org/movieontology">
        <rdfs:label xml:lang="en">Movie Knowledge Graph Ontology (v2)</rdfs:label>
        <rdfs:comment xml:lang="en">An OWL 2 ontology for representing movies, persons (actors, directors, writers, producers, composers), genres, awards, production companies, countries, languages, franchises, TV series, episodes and streaming platforms. Designed for an IMDb-like knowledge graph with SPARQL querying, ontology population from Wikidata/TMDb, and LLM-driven QA. Version 2 extends the base schema with TV/streaming concepts, alignment to schema.org / DBpedia / Wikidata / Bouza MO, and SHACL-ready cardinality patterns.</rdfs:comment>
        <owl:versionInfo>2.0</owl:versionInfo>
        <owl:versionIRI rdf:resource="http://www.semanticweb.org/movieontology/2.0"/>
        <owl:priorVersion rdf:resource="http://www.semanticweb.org/movieontology/1.0"/>
        <dc:creator>Gulsum Ceylan</dc:creator>
        <dc:creator>Furkan Ustuncan</dc:creator>
        <dc:date rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-05-11</dc:date>
        <dcterms:license rdf:resource="https://opensource.org/licenses/MIT"/>
        <rdfs:seeAlso rdf:resource="http://www.movieontology.org/2009/11/09/movieontology.owl"/>
        <rdfs:seeAlso rdf:resource="http://schema.org/Movie"/>
        <rdfs:seeAlso rdf:resource="http://dbpedia.org/ontology/Film"/>
        <rdfs:seeAlso rdf:resource="http://www.wikidata.org/entity/Q11424"/>
    </owl:Ontology>

    <!-- =========================================== -->
    <!-- ===========    OBJECT PROPERTIES    ======= -->
    <!-- =========================================== -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/movieontology#hasActor">
        <rdfs:label xml:lang="en">has actor</rdfs:label>
        <rdfs:comment xml:lang="en">Relates an audiovisual work to a person who acts in it. Inverse of actsIn.</rdfs:comment>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/movieontology#AudiovisualWork"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/movieontology#Actor"/>
        <owl:inverseOf rdf:resource="http://www.semanticweb.org/movieontology#actsIn"/>
        <rdfs:seeAlso rdf:resource="http://schema.org/actor"/>
        <rdfs:seeAlso rdf:resource="http://dbpedia.org/ontology/starring"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/movieontology#actsIn">
        <rdfs:label xml:lang="en">acts in</rdfs:label>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/movieontology#Actor"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/movieontology#AudiovisualWork"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/movieontology#hasDirector">
        <rdfs:label xml:lang="en">has director</rdfs:label>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/movieontology#AudiovisualWork"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/movieontology#Director"/>
        <owl:inverseOf rdf:resource="http://www.semanticweb.org/movieontology#directs"/>
        <rdfs:seeAlso rdf:resource="http://schema.org/director"/>
        <rdfs:seeAlso rdf:resource="http://dbpedia.org/ontology/director"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/movieontology#directs">
        <rdfs:label xml:lang="en">directs</rdfs:label>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/movieontology#Director"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/movieontology#Movie"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/movieontology#hasProducer">
        <rdfs:label xml:lang="en">has producer</rdfs:label>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/movieontology#AudiovisualWork"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/movieontology#Producer"/>
        <rdfs:seeAlso rdf:resource="http://schema.org/producer"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/movieontology#hasWriter">
        <rdfs:label xml:lang="en">has writer</rdfs:label>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/movieontology#AudiovisualWork"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/movieontology#Writer"/>
        <rdfs:seeAlso rdf:resource="http://schema.org/author"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/movieontology#hasComposer">
        <rdfs:label xml:lang="en">has composer</rdfs:label>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/movieontology#AudiovisualWork"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/movieontology#Composer"/>
        <rdfs:seeAlso rdf:resource="http://schema.org/musicBy"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/movieontology#hasGenre">
        <rdfs:label xml:lang="en">has genre</rdfs:label>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/movieontology#AudiovisualWork"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/movieontology#Genre"/>
        <rdfs:seeAlso rdf:resource="http://schema.org/genre"/>
        <rdfs:seeAlso rdf:resource="http://dbpedia.org/ontology/genre"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/movieontology#hasWonAward">
        <rdfs:label xml:lang="en">has won award</rdfs:label>
        <rdfs:comment xml:lang="en">Relates a movie or person to an award they have won.</rdfs:comment>
        <rdfs:range rdf:resource="http://www.semanticweb.org/movieontology#Award"/>
        <rdfs:seeAlso rdf:resource="http://schema.org/award"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/movieontology#producedBy">
        <rdfs:label xml:lang="en">produced by</rdfs:label>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/movieontology#Movie"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/movieontology#ProductionCompany"/>
        <rdfs:seeAlso rdf:resource="http://schema.org/productionCompany"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/movieontology#filmedIn">
        <rdfs:label xml:lang="en">filmed in</rdfs:label>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/movieontology#Movie"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/movieontology#Country"/>
        <rdfs:seeAlso rdf:resource="http://schema.org/countryOfOrigin"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/movieontology#inLanguage">
        <rdfs:label xml:lang="en">in language</rdfs:label>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/movieontology#Movie"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/movieontology#Language"/>
        <rdfs:seeAlso rdf:resource="http://schema.org/inLanguage"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/movieontology#partOfFranchise">
        <rdfs:label xml:lang="en">part of franchise</rdfs:label>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/movieontology#Movie"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/movieontology#Franchise"/>
        <rdfs:seeAlso rdf:resource="http://schema.org/partOfSeries"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/movieontology#bornIn">
        <rdfs:label xml:lang="en">born in</rdfs:label>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/movieontology#Person"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/movieontology#Country"/>
        <rdfs:seeAlso rdf:resource="http://schema.org/birthPlace"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/movieontology#collaboratesWith">
        <rdfs:label xml:lang="en">collaborates with</rdfs:label>
        <rdfs:comment xml:lang="en">Symmetric: if A collaboratesWith B then B collaboratesWith A.</rdfs:comment>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#SymmetricProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/movieontology#Person"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/movieontology#Person"/>
    </owl:ObjectProperty>

    <!-- ===== NEW (v2) Object Properties for TV/Streaming ===== -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/movieontology#hasEpisode">
        <rdfs:label xml:lang="en">has episode</rdfs:label>
        <rdfs:comment xml:lang="en">Relates a TV series to one of its episodes.</rdfs:comment>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/movieontology#TVSeries"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/movieontology#Episode"/>
        <owl:inverseOf rdf:resource="http://www.semanticweb.org/movieontology#episodeOf"/>
        <rdfs:seeAlso rdf:resource="http://schema.org/episode"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/movieontology#episodeOf">
        <rdfs:label xml:lang="en">episode of</rdfs:label>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/movieontology#Episode"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/movieontology#TVSeries"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/movieontology#availableOn">
        <rdfs:label xml:lang="en">available on</rdfs:label>
        <rdfs:comment xml:lang="en">Relates a movie or TV series to a streaming platform that distributes it.</rdfs:comment>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/movieontology#AudiovisualWork"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/movieontology#StreamingPlatform"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/movieontology#basedOn">
        <rdfs:label xml:lang="en">based on</rdfs:label>
        <rdfs:comment xml:lang="en">Relates a movie to a source work (book, comic, true story) it is adapted from.</rdfs:comment>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/movieontology#Movie"/>
        <rdfs:seeAlso rdf:resource="http://schema.org/isBasedOn"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/movieontology#sequelOf">
        <rdfs:label xml:lang="en">sequel of</rdfs:label>
        <rdfs:comment xml:lang="en">Relates a movie to its prequel; inverse of prequelOf.</rdfs:comment>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/movieontology#Movie"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/movieontology#Movie"/>
        <owl:inverseOf rdf:resource="http://www.semanticweb.org/movieontology#prequelOf"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/movieontology#prequelOf">
        <rdfs:label xml:lang="en">prequel of</rdfs:label>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/movieontology#Movie"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/movieontology#Movie"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/movieontology#playsCharacter">
        <rdfs:label xml:lang="en">plays character</rdfs:label>
        <rdfs:comment xml:lang="en">Relates an actor (in the context of a specific movie) to a fictional character they portray.</rdfs:comment>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/movieontology#Actor"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/movieontology#Character"/>
    </owl:ObjectProperty>

    <!-- =========================================== -->
    <!-- ===========    DATA PROPERTIES      ======= -->
    <!-- =========================================== -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/movieontology#title">
        <rdfs:label xml:lang="en">title</rdfs:label>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/movieontology#Movie"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:seeAlso rdf:resource="http://schema.org/name"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/movieontology#releaseYear">
        <rdfs:label xml:lang="en">release year</rdfs:label>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/movieontology#Movie"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:seeAlso rdf:resource="http://schema.org/datePublished"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/movieontology#duration">
        <rdfs:label xml:lang="en">duration in minutes</rdfs:label>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/movieontology#Movie"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:seeAlso rdf:resource="http://schema.org/duration"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/movieontology#imdbRating">
        <rdfs:label xml:lang="en">IMDb rating</rdfs:label>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/movieontology#Movie"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/movieontology#budget">
        <rdfs:label xml:lang="en">budget in USD</rdfs:label>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/movieontology#Movie"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#long"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/movieontology#boxOffice">
        <rdfs:label xml:lang="en">box office in USD</rdfs:label>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/movieontology#Movie"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#long"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/movieontology#fullName">
        <rdfs:label xml:lang="en">full name</rdfs:label>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/movieontology#Person"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/movieontology#birthDate">
        <rdfs:label xml:lang="en">birth date</rdfs:label>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/movieontology#Person"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/movieontology#awardYear">
        <rdfs:label xml:lang="en">award year</rdfs:label>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/movieontology#Award"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
    </owl:DatatypeProperty>

    <!-- ===== NEW (v2) Data Properties ===== -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/movieontology#plotSummary">
        <rdfs:label xml:lang="en">plot summary</rdfs:label>
        <rdfs:comment xml:lang="en">A short textual description of the plot. Useful for LLM-driven QA and ontology population.</rdfs:comment>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/movieontology#Movie"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:seeAlso rdf:resource="http://schema.org/description"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/movieontology#imdbId">
        <rdfs:label xml:lang="en">IMDb identifier</rdfs:label>
        <rdfs:comment xml:lang="en">External identifier on IMDb (e.g. tt1375666).</rdfs:comment>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/movieontology#tmdbId">
        <rdfs:label xml:lang="en">TMDb identifier</rdfs:label>
        <rdfs:comment xml:lang="en">External identifier on The Movie Database (TMDb).</rdfs:comment>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/movieontology#wikidataId">
        <rdfs:label xml:lang="en">Wikidata identifier</rdfs:label>
        <rdfs:comment xml:lang="en">Wikidata QID (e.g. Q25188 for Inception).</rdfs:comment>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/movieontology#seasonNumber">
        <rdfs:label xml:lang="en">season number</rdfs:label>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/movieontology#Episode"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/movieontology#episodeNumber">
        <rdfs:label xml:lang="en">episode number</rdfs:label>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/movieontology#Episode"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
    </owl:DatatypeProperty>

    <!-- =========================================== -->
    <!-- ===========       CLASSES           ======= -->
    <!-- =========================================== -->

    <!-- Common superclass introduced in v2 to allow shared properties across film and TV -->
    <owl:Class rdf:about="http://www.semanticweb.org/movieontology#AudiovisualWork">
        <rdfs:label xml:lang="en">Audiovisual Work</rdfs:label>
        <rdfs:comment xml:lang="en">Abstract superclass covering any cinematic or televisual work (movies, TV series, episodes).</rdfs:comment>
        <rdfs:seeAlso rdf:resource="http://schema.org/CreativeWork"/>
    </owl:Class>

    <owl:Class rdf:about="http://www.semanticweb.org/movieontology#Movie">
        <rdfs:label xml:lang="en">Movie</rdfs:label>
        <rdfs:comment xml:lang="en">A cinematographic work.</rdfs:comment>
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/movieontology#AudiovisualWork"/>
        <rdfs:seeAlso rdf:resource="http://schema.org/Movie"/>
        <rdfs:seeAlso rdf:resource="http://dbpedia.org/ontology/Film"/>
        <rdfs:seeAlso rdf:resource="http://www.wikidata.org/entity/Q11424"/>
    </owl:Class>

    <owl:Class rdf:about="http://www.semanticweb.org/movieontology#FeatureFilm">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/movieontology#Movie"/>
        <rdfs:label xml:lang="en">Feature Film</rdfs:label>
    </owl:Class>

    <owl:Class rdf:about="http://www.semanticweb.org/movieontology#ShortFilm">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/movieontology#Movie"/>
        <rdfs:label xml:lang="en">Short Film</rdfs:label>
    </owl:Class>

    <owl:Class rdf:about="http://www.semanticweb.org/movieontology#Documentary">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/movieontology#Movie"/>
        <rdfs:label xml:lang="en">Documentary</rdfs:label>
    </owl:Class>

    <owl:Class rdf:about="http://www.semanticweb.org/movieontology#AnimatedMovie">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/movieontology#Movie"/>
        <rdfs:label xml:lang="en">Animated Movie</rdfs:label>
    </owl:Class>

    <!-- ===== NEW (v2) Classes: TV / Streaming ===== -->

    <owl:Class rdf:about="http://www.semanticweb.org/movieontology#TVSeries">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/movieontology#AudiovisualWork"/>
        <rdfs:label xml:lang="en">TV Series</rdfs:label>
        <rdfs:seeAlso rdf:resource="http://schema.org/TVSeries"/>
        <rdfs:seeAlso rdf:resource="http://www.wikidata.org/entity/Q5398426"/>
    </owl:Class>

    <owl:Class rdf:about="http://www.semanticweb.org/movieontology#Episode">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/movieontology#AudiovisualWork"/>
        <rdfs:label xml:lang="en">Episode</rdfs:label>
        <rdfs:seeAlso rdf:resource="http://schema.org/Episode"/>
    </owl:Class>

    <owl:Class rdf:about="http://www.semanticweb.org/movieontology#StreamingPlatform">
        <rdfs:label xml:lang="en">Streaming Platform</rdfs:label>
        <rdfs:comment xml:lang="en">A digital distribution service for films and TV (Netflix, Disney+, etc.).</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="http://www.semanticweb.org/movieontology#Character">
        <rdfs:label xml:lang="en">Character</rdfs:label>
        <rdfs:comment xml:lang="en">A fictional character portrayed in a movie or TV work.</rdfs:comment>
    </owl:Class>

    <!-- ===== Person classes ===== -->

    <owl:Class rdf:about="http://www.semanticweb.org/movieontology#Person">
        <rdfs:label xml:lang="en">Person</rdfs:label>
        <rdfs:comment xml:lang="en">A human being involved in the movie industry.</rdfs:comment>
        <rdfs:seeAlso rdf:resource="http://schema.org/Person"/>
        <rdfs:seeAlso rdf:resource="http://xmlns.com/foaf/0.1/Person"/>
    </owl:Class>

    <owl:Class rdf:about="http://www.semanticweb.org/movieontology#Actor">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/movieontology#Person"/>
        <rdfs:label xml:lang="en">Actor</rdfs:label>
    </owl:Class>

    <owl:Class rdf:about="http://www.semanticweb.org/movieontology#Director">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/movieontology#Person"/>
        <rdfs:label xml:lang="en">Director</rdfs:label>
    </owl:Class>

    <owl:Class rdf:about="http://www.semanticweb.org/movieontology#Producer">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/movieontology#Person"/>
        <rdfs:label xml:lang="en">Producer</rdfs:label>
    </owl:Class>

    <owl:Class rdf:about="http://www.semanticweb.org/movieontology#Writer">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/movieontology#Person"/>
        <rdfs:label xml:lang="en">Writer</rdfs:label>
