:availableOn a owl:ObjectProperty ;
    rdfs:label "available on"@en ;
    rdfs:comment "Relates a movie or TV series to a streaming platform that distributes it."@en ;
    rdfs:domain :AudiovisualWork ;
    rdfs:range :StreamingPlatform .

:awardYear a owl:DatatypeProperty ;
    rdfs:label "award year"@en ;
    rdfs:domain :Award ;
    rdfs:range xsd:integer .

:basedOn a owl:ObjectProperty ;
    rdfs:label "based on"@en ;
    rdfs:comment "Relates a movie to a source work (book, comic, true story) it is adapted from."@en ;
    rdfs:domain :Movie ;
    rdfs:seeAlso schema1:isBasedOn .

:birthDate a owl:DatatypeProperty ;
    rdfs:label "birth date"@en ;
    rdfs:domain :Person ;
    rdfs:range xsd:date .

:bornIn a owl:ObjectProperty ;
    rdfs:label "born in"@en ;
    rdfs:domain :Person ;
    rdfs:range :Country ;
    rdfs:seeAlso schema1:birthPlace .

:boxOffice a owl:DatatypeProperty ;
    rdfs:label "box office in USD"@en ;
    rdfs:domain :Movie ;
    rdfs:range xsd:long .

:budget a owl:DatatypeProperty ;
    rdfs:label "budget in USD"@en ;
    rdfs:domain :Movie ;
    rdfs:range xsd:long .

:collaboratesWith a owl:ObjectProperty,
        owl:SymmetricProperty ;
    rdfs:label "collaborates with"@en ;
    rdfs:comment "Symmetric: if A collaboratesWith B then B collaboratesWith A."@en ;
    rdfs:domain :Person ;
    rdfs:range :Person .

:duration a owl:DatatypeProperty ;
    rdfs:label "duration in minutes"@en ;
    rdfs:domain :Movie ;
    rdfs:range xsd:integer ;
    rdfs:seeAlso schema1:duration .

:episodeNumber a owl:DatatypeProperty ;
    rdfs:label "episode number"@en ;
    rdfs:domain :Episode ;
    rdfs:range xsd:integer .

:filmedIn a owl:ObjectProperty ;
    rdfs:label "filmed in"@en ;
    rdfs:domain :Movie ;
    rdfs:range :Country ;
    rdfs:seeAlso schema1:countryOfOrigin .

:fullName a owl:DatatypeProperty ;
    rdfs:label "full name"@en ;
    rdfs:domain :Person ;
    rdfs:range xsd:string .

:hasActor a owl:ObjectProperty ;
    rdfs:label "has actor"@en ;
    rdfs:comment "Relates an audiovisual work to a person who acts in it. Inverse of actsIn."@en ;
    rdfs:domain :AudiovisualWork ;
    rdfs:range :Actor ;
    rdfs:seeAlso dbo:starring,
        schema1:actor ;
    owl:inverseOf :actsIn .

:hasComposer a owl:ObjectProperty ;
    rdfs:label "has composer"@en ;
    rdfs:domain :AudiovisualWork ;
    rdfs:range :Composer ;
    rdfs:seeAlso schema1:musicBy .

:hasDirector a owl:ObjectProperty ;
    rdfs:label "has director"@en ;
    rdfs:domain :AudiovisualWork ;
    rdfs:range :Director ;
    rdfs:seeAlso dbo:director,
        schema1:director ;
    owl:inverseOf :directs .

:hasEpisode a owl:ObjectProperty ;
    rdfs:label "has episode"@en ;
    rdfs:comment "Relates a TV series to one of its episodes."@en ;
    rdfs:domain :TVSeries ;
    rdfs:range :Episode ;
    rdfs:seeAlso schema1:episode ;
    owl:inverseOf :episodeOf .

:hasGenre a owl:ObjectProperty ;
    rdfs:label "has genre"@en ;
    rdfs:domain :AudiovisualWork ;
    rdfs:range :Genre ;
    rdfs:seeAlso dbo:genre,
        schema1:genre .

:hasProducer a owl:ObjectProperty ;
    rdfs:label "has producer"@en ;
    rdfs:domain :AudiovisualWork ;
    rdfs:range :Producer ;
    rdfs:seeAlso schema1:producer .

:hasWonAward a owl:ObjectProperty ;
    rdfs:label "has won award"@en ;
    rdfs:comment "Relates a movie or person to an award they have won."@en ;
    rdfs:range :Award ;
    rdfs:seeAlso schema1:award .

:hasWriter a owl:ObjectProperty ;
    rdfs:label "has writer"@en ;
    rdfs:domain :AudiovisualWork ;
    rdfs:range :Writer ;
    rdfs:seeAlso schema1:author .

:imdbId a owl:DatatypeProperty ;
    rdfs:label "IMDb identifier"@en ;
    rdfs:comment "External identifier on IMDb (e.g. tt1375666)."@en ;
    rdfs:range xsd:string .

:imdbRating a owl:DatatypeProperty ;
    rdfs:label "IMDb rating"@en ;
    rdfs:domain :Movie ;
    rdfs:range xsd:float .

:inLanguage a owl:ObjectProperty ;
    rdfs:label "in language"@en ;
    rdfs:domain :Movie ;
    rdfs:range :Language ;
    rdfs:seeAlso schema1:inLanguage .

:partOfFranchise a owl:ObjectProperty ;
    rdfs:label "part of franchise"@en ;
    rdfs:domain :Movie ;
    rdfs:range :Franchise ;
    rdfs:seeAlso schema1:partOfSeries .

:playsCharacter a owl:ObjectProperty ;
    rdfs:label "plays character"@en ;
    rdfs:comment "Relates an actor (in the context of a specific movie) to a fictional character they portray."@en ;
    rdfs:domain :Actor ;
    rdfs:range :Character .

:plotSummary a owl:DatatypeProperty ;
    rdfs:label "plot summary"@en ;
    rdfs:comment "A short textual description of the plot. Useful for LLM-driven QA and ontology population."@en ;
    rdfs:domain :Movie ;
    rdfs:range xsd:string ;
    rdfs:seeAlso schema1:description .

:producedBy a owl:ObjectProperty ;
    rdfs:label "produced by"@en ;
    rdfs:domain :Movie ;
    rdfs:range :ProductionCompany ;
    rdfs:seeAlso schema1:productionCompany .

:releaseYear a owl:DatatypeProperty ;
    rdfs:label "release year"@en ;
    rdfs:domain :Movie ;
    rdfs:range xsd:integer ;
    rdfs:seeAlso schema1:datePublished .

:seasonNumber a owl:DatatypeProperty ;
    rdfs:label "season number"@en ;
    rdfs:domain :Episode ;
    rdfs:range xsd:integer .

:sequelOf a owl:ObjectProperty ;
    rdfs:label "sequel of"@en ;
    rdfs:comment "Relates a movie to its prequel; inverse of prequelOf."@en ;
    rdfs:domain :Movie ;
    rdfs:range :Movie ;
    owl:inverseOf :prequelOf .

:title a owl:DatatypeProperty ;
    rdfs:label "title"@en ;
    rdfs:domain :Movie ;
    rdfs:range xsd:string ;
    rdfs:seeAlso schema1:name .

:tmdbId a owl:DatatypeProperty ;
    rdfs:label "TMDb identifier"@en ;
    rdfs:comment "External identifier on The Movie Database (TMDb)."@en ;
    rdfs:range xsd:string .

:wikidataId a owl:DatatypeProperty ;
    rdfs:label "Wikidata identifier"@en ;
    rdfs:comment "Wikidata QID (e.g. Q25188 for Inception)."@en ;
    rdfs:range xsd:string .

