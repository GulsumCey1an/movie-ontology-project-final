@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://www.semanticweb.org/movieontology> a owl:Ontology ;
    rdfs:label "Movie Knowledge Graph Ontology (v2)"@en ;
    dc:creator "Furkan Ustuncan",
        "Gulsum Ceylan" ;
    dc:date "2026-05-11"^^xsd:date ;
    dcterms:license <https://opensource.org/licenses/MIT> ;
    rdfs:comment "An OWL 2 ontology for representing movies, persons (actors, directors, writers, producers, composers), genres, awards, production companies, countries, languages, franchises, TV series, episodes and streaming platforms. Designed for an IMDb-like knowledge graph with SPARQL querying, ontology population from Wikidata/TMDb, and LLM-driven QA. Version 2 extends the base schema with TV/streaming concepts, alignment to schema.org / DBpedia / Wikidata / Bouza MO, and SHACL-ready cardinality patterns."@en ;
    rdfs:seeAlso dbo:Film,
        schema1:Movie,
        <http://www.movieontology.org/2009/11/09/movieontology.owl>,
        wd:Q11424 ;
    owl:priorVersion <http://www.semanticweb.org/movieontology/1.0> ;
    owl:versionIRI <http://www.semanticweb.org/movieontology/2.0> ;
    owl:versionInfo "2.0" .

